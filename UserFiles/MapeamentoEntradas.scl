TYPE "udtBotaoReset"
VERSION : 0.1
   STRUCT
      i_bReset : Bool;   // Sinal do botão de reset
      q_bLEDResetHabilitado : Bool;   // Comando do LED do botão de reset
   END_STRUCT;

END_TYPE

TYPE "udtBotaoComando"
VERSION : 0.1
   STRUCT
      i_bOnOff : Bool;   // Botao LIGA/Desliga no campo (pulsado)
      q_bLEDLinhaOperando : Bool;   // Sinal para ligar LED no quadro indicando linha em operação
   END_STRUCT;

END_TYPE

TYPE "udtBotaoSolicitaAcesso"
VERSION : 0.1
   STRUCT
      i_bSolicitaAcesso : Bool;   // Sinal do botão de solicitar acesso
      q_bLEDSolicitaAcesso : Bool;   // Comando do LED do botão de solicitar acesso
      q_bBobinaLiberaAcesso : Bool;   // Sinal para bobina da chave de porta para liberar acesso
   END_STRUCT;

END_TYPE

TYPE "udtTorreSinalizacao"
VERSION : 0.1
   STRUCT
      q_bLampVerde : Bool;   // Sinal para lampada verde
      q_bLampVermelha : Bool;   // Sinal para lampada vermelha
      q_bLampAzul : Bool;   // Sinal para lampada azul
      q_bLampAmarela : Bool;   // Sinal para lampada amarela
      q_bSirene : Bool;   // Sinal para sirene
   END_STRUCT;

END_TYPE

TYPE "ST_Contactor"
VERSION : 0.1
   STRUCT
      i_xEnableConfirmation : Bool;
      q_xEnable : Bool;
   END_STRUCT;

END_TYPE

DATA_BLOCK "dbMapeamentoIO"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
NON_RETAIN
   VAR 
      abSensor : Array[0..64] of Bool;
