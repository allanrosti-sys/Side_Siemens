      stS21_3 : "udtBotaoComando";
      stS17_1_2 : "udtBotaoReset";
      stS17_1_3 : "udtBotaoComando";
      stS17_1_4 : "udtBotaoSolicitaAcesso";
      stS17_2_2 : "udtBotaoReset";
      stS17_2_4 : "udtBotaoSolicitaAcesso";
      stS17_3_2 : "udtBotaoReset";
      stS17_3_3 : "udtBotaoComando";
      stS17_3_4 : "udtBotaoSolicitaAcesso";
      stS17_4_2 : "udtBotaoReset";
      stS17_4_4 : "udtBotaoSolicitaAcesso";
      stS17_5_2 : "udtBotaoReset";
      stS17_5_4 : "udtBotaoSolicitaAcesso";
      stS17_6_2 : "udtBotaoReset";
      stS17_6_4 : "udtBotaoSolicitaAcesso";
      stS17_7_2 : "udtBotaoReset";
      stS17_7_4 : "udtBotaoSolicitaAcesso";
      stX17 : "udtTorreSinalizacao";
      stK1 : "ST_Contactor";
      stK2 : "ST_Contactor";
      stK3 : "ST_Contactor";
      stK4 : "ST_Contactor";
      stK5 : "ST_Contactor";
      stK6 : "ST_Contactor";
      stK7 : "ST_Contactor";
      stK8 : "ST_Contactor";
      stK9 : "ST_Contactor";
      stK10 : "ST_Contactor";
      stK11 : "ST_Contactor";
      bInOutModeSelector : Bool;   // 0 - Palete de fora vai pra envolver; 1 - Desvia palete para fora da celula (sem envolver)
   END_VAR


BEGIN

END_DATA_BLOCK

